{
  "name": "@anchor_app/anchor",
  "version": "1.8.0",
  "type": "module",
  "bin": {
    "anchor": "./dist/index.cjs"
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "pnpm --filter @anchor_app/core build && vitest run",
    "test:integration": "pnpm --filter @anchor_app/core build && vitest run tests/integration",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anchor_app/core": "workspace:*",
    "commander": "^14.0.1"
  }
}
